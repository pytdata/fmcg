# ─── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/kw_enterprise

# ─── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_replace_before_production

# ─── PayStack ──────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Gmail SMTP ────────────────────────────────────────────────────────────
GMAIL_EMAIL=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=KW Enterprise
EMAIL_FROM_ADDRESS=noreply@kwenterprise.com

# ─── cSMS ──────────────────────────────────────────────────────────────────
CSMS_API_KEY=your_csms_api_key_here
CSMS_SENDER_ID=KWENTERPRISE

# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
