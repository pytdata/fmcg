# ════════════════════════════════════════════════════════════════════════════
# KW Enterprise – Backend Environment Variables  (server/.env)
# Copy this file to server/.env and fill in all values before starting.
# ════════════════════════════════════════════════════════════════════════════

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# Full connection string to your PostgreSQL database.
# FREE hosted options:
#   • Neon       → https://neon.tech          (free tier, serverless Postgres)
#   • Supabase   → https://supabase.com        (free tier, includes dashboard)
#   • Railway    → https://railway.app         (easy deploy)
#   • Render     → https://render.com          (managed Postgres)
#
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example (Neon):    postgresql://alex:abc123@ep-cool-thing-123.us-east-2.aws.neon.tech/neondb?sslmode=require
# Example (local):   postgresql://postgres:password@localhost:5432/kw_enterprise
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# ─── JWT ────────────────────────────────────────────────────────────────────
# Long random secret used to sign JWTs. NEVER share or commit this value.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_hex_string

# ─── PayStack ───────────────────────────────────────────────────────────────
# Secret key from PayStack dashboard → Settings → API Keys & Webhooks
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# ─── Gmail SMTP (for order notification emails) ─────────────────────────────
# Your Gmail address that sends notification emails.
GMAIL_EMAIL=youremail@gmail.com
#
# A Google App Password (NOT your regular password).
# Generate at: https://myaccount.google.com/apppasswords
# Must have 2-Step Verification enabled on your Google account.
# Format: 16 characters, no spaces (e.g. abcdwxyzefghijkl)
GMAIL_APP_PASSWORD=abcd wxyz efgh ijkl
#
# "From" display name and address shown in emails to customers
EMAIL_FROM_NAME=KW Enterprise
EMAIL_FROM_ADDRESS=noreply@kwenterprise.com

# ─── cSMS (for order notification SMS) ──────────────────────────────────────
# API key from your cSMS dashboard: https://app.mycsms.com → Settings → API
CSMS_API_KEY=your_csms_api_key_here
# Sender ID registered with cSMS (alphanumeric, max 11 characters)
CSMS_SENDER_ID=KWENTERPRISE

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── CORS / Frontend URL ─────────────────────────────────────────────────────
# The URL where your frontend is hosted (no trailing slash).
# This is used for CORS — must match exactly what the browser sends as Origin.
FRONTEND_URL=https://your-frontend-domain.com

