# ════════════════════════════════════════════════════════════════════════════
# KW Enterprise – Frontend Environment Variables  (root .env)
# Copy this file to .env and fill in all values before building/running.
# ════════════════════════════════════════════════════════════════════════════

# ─── App ID (do not change) ──────────────────────────────────────────────────
VITE_APP_ID=app-bojrafz0d6v5

# ─── Express Backend URL ─────────────────────────────────────────────────────
# Full URL where your Express server is running (no trailing slash).
# Development:  http://localhost:3001
# Production:   https://api.your-domain.com  (Railway, Render, etc.)
VITE_API_URL=http://localhost:3001

# ─── PayStack Public Key ─────────────────────────────────────────────────────
# PUBLIC key only (safe to expose to browser). From:
# PayStack Dashboard → Settings → API Keys & Webhooks
VITE_PAYSTACK_PUBLIC_KEY=your_paystack_public_key_here

